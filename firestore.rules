okayrules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Admins collection
    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false;
    }
    
    // Users collection - admins can read/write all
    match /users/{userId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow create: if isAdmin();
      allow update: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow delete: if isAdmin();
    }
    
    // Partners collection - admins can read/write all
    match /partners/{partnerId} {
      allow read: if isAdmin() || request.auth != null;
      allow create: if request.auth != null && request.auth.uid == partnerId;
      allow update: if isAdmin() || (request.auth != null && request.auth.uid == partnerId);
      allow delete: if isAdmin();
    }
    
    // Waste requests - admins can read/write all
    match /wasteRequests/{requestId} {
      allow read: if isAdmin() || request.auth != null;
      allow create: if request.auth != null;
      allow update: if isAdmin() || request.auth != null;
      allow delete: if isAdmin();
    }
    
    // Notifications - admins can read all
    match /notifications/{notificationId} {
      allow read: if isAdmin() || 
                     (request.auth != null && resource.data.partnerId == request.auth.uid) ||
                     (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null;
      allow update: if isAdmin() || request.auth != null;
      allow delete: if isAdmin();
    }
    
    // Other collections - admins have full access
    match /{document=**} {
      allow read: if isAdmin() || request.auth != null;
      allow write: if isAdmin() || request.auth != null;
    }
  }
}